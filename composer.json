{
    "name": "docile/support",
    "description": "Docile framework support utilities: Str, Arr, Collection, Pipeline, Env, Clock.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ali Naqi Al-Musawi",
            "email": "alinaqi2000@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "psr/clock": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Docile\\Support\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Docile\\Support\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    }
}
